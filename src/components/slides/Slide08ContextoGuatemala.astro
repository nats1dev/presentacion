<!-- ============ 07b · CONTEXTO GUATEMALA ============ -->
  <section data-label="Contexto Guatemala">
    <div class="slide center-y" data-screen-label="Contexto Guatemala">
      <div class="kicker anim anim-1">Contexto real</div>
      <h2 class="big-statement anim anim-2" style="max-width:34ch; font-size:54px;">
        En Guatemala, la <span class="accent-rust">ausencia de mantenimiento</span> periódico ya tiene consecuencias documentadas.
      </h2>
      <div style="display:flex; gap:48px; margin-top:40px;" class="anim anim-3">
        <div style="flex:1; min-width:0;">
          <p style="font-size:27px; color:var(--muted); line-height:1.6; max-width:52ch;">
            El <b style="color:var(--ink)">puente sobre el Río Dulce</b> (1977–1980) acumula daños
            calificados como <b style="color:var(--rust)">«severos»</b> por la CONRED en informes
            de 2017, 2022 y 2024. No se ha ejecutado un plan permanente de mantenimiento;
            el CIV evalúa la necesidad de construir un paso alterno.
          </p>
          <p style="font-size:24px; color:var(--muted); line-height:1.5; max-width:52ch; margin-top:24px;">
            El sector construcción se caracteriza por una <b style="color:var(--ink)">adopción tecnológica lenta</b>,
            lo que contrasta con el avance de la IA. Esta brecha es una oportunidad para integrar
            herramientas computacionales en la evaluación estructural.
          </p>
        </div>
        <div style="flex:0 0 auto; display:flex; flex-direction:column; gap:18px;">
          <div style="background:var(--card); border-radius:14px; padding:28px 32px; min-width:320px;">
            <div style="font-family:var(--font-mono); font-size:15px; text-transform:uppercase; letter-spacing:.08em; color:var(--faint); margin-bottom:8px;">El problema recurrente</div>
            <div style="font-size:23px; color:var(--ink); line-height:1.4;">Ausencia de evaluaciones periódicas sobre recubrimientos anticorrosivos en elementos metálicos</div>
          </div>
          <div style="background:var(--card); border-radius:14px; padding:28px 32px; min-width:320px;">
            <div style="font-family:var(--font-mono); font-size:15px; text-transform:uppercase; letter-spacing:.08em; color:var(--faint); margin-bottom:8px;">Lo que se necesita</div>
            <div style="font-size:23px; color:var(--ink); line-height:1.4;">Inspección no destructiva, sistemática, objetiva y replicable</div>
          </div>
        </div>
      </div>
      <div class="foot"><span class="foot-title">Detección de corrosión · CNN</span><span class="foot-num"></span></div>
    </div>
  </section>
